<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Just a few more questions"
        android:textColor="@color/dark_text"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_height_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="How tall are you?"
        android:textColor="@color/gray_text"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_title" />

    <LinearLayout
        android:id="@+id/ll_height"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/tv_height_label">

        <EditText
            android:id="@+id/et_height_ft"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_setup_card"
            android:hint="Feet"
            android:gravity="center"
            android:inputType="number"
            android:textColor="@color/dark_text"
            android:textColorHint="@color/gray_text" />

        <EditText
            android:id="@+id/et_height_in"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_setup_card"
            android:hint="Inches"
            android:gravity="center"
            android:inputType="number"
            android:textColor="@color/dark_text"
            android:textColorHint="@color/gray_text" />

        <TextView
            android:layout_width="80dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_setup_card"
            android:gravity="center"
            android:text="ft/in"
            android:textColor="@color/primary_green"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_weight_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="How much do you Weight?"
        android:textColor="@color/gray_text"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ll_height" />

    <LinearLayout
        android:id="@+id/ll_weight"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/tv_weight_label">

        <EditText
            android:id="@+id/et_weight"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_setup_card"
            android:hint="Enter weight"
            android:gravity="center"
            android:inputType="number"
            android:textColor="@color/dark_text"
            android:textColorHint="@color/gray_text" />

        <TextView
            android:layout_width="80dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_setup_card"
            android:gravity="center"
            android:text="kg"
            android:textColor="@color/primary_green"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_goal_weight_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="What's your goal weight?"
        android:textColor="@color/gray_text"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ll_weight" />

    <LinearLayout
        android:id="@+id/ll_goal_weight"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/tv_goal_weight_label">

        <EditText
            android:id="@+id/et_goal_weight"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_setup_card"
            android:hint="Enter goal weight"
            android:gravity="center"
            android:inputType="number"
            android:textColor="@color/dark_text"
            android:textColorHint="@color/gray_text" />

        <TextView
            android:layout_width="80dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_setup_card"
            android:gravity="center"
            android:text="kg"
            android:textColor="@color/gray_text"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_weight_difference"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text=""
        android:textColor="@color/primary_green"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ll_goal_weight" />

</androidx.constraintlayout.widget.ConstraintLayout>